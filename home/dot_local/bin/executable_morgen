#!/usr/bin/env bash
# morgen — kurzes Arbeitstag-Onboarding fürs Terminal. Kaffee, Überblick, Fokus.
#
# Motion-Tasks brauchen einen API-Key (Motion → Settings → API-Key erstellen):
#   pass insert motion/api-key         ODER      export MOTION_API_KEY=... (secrets.zsh)
# Motion-API ist rate-limitiert (einige Requests/Minute) — 1x morgens ist unkritisch.
# Hinweis: Feldnamen/Base-URL der Motion-API ggf. an docs.usemotion.com anpassen;
# der Rest des Briefings läuft unabhängig davon.
set -uo pipefail
b() { printf '\033[1;35m'; }; y() { printf '\033[1;33m'; }; g() { printf '\033[1;32m'; }
d() { printf '\033[90m'; };  cy() { printf '\033[36m'; };  z() { printf '\033[0m'; }
rule() { printf '%s\n' "──────────────────────────────────────────────"; }

printf "\n"; b; printf "☕  Guten Morgen, %s — %s" "$(id -un)" "$(date '+%A, %d. %B %Y')"; z; printf "\n"
rule

# Wetter (kurz, mit Timeout — nie blockierend)
W="$(curl -fsS --max-time 4 'wttr.in/Mainz?format=%c+%t,+gefühlt+%f,+%p+Niederschlag' 2>/dev/null || true)"
[ -n "$W" ] && { cy; printf " %s" "$W"; z; printf "\n"; }

# Motion — heute
KEY="${MOTION_API_KEY:-$(pass show motion/api-key 2>/dev/null || true)}"
if [ -n "$KEY" ] && command -v jq >/dev/null 2>&1; then
  TODAY="$(date +%Y-%m-%d)"
  JSON="$(curl -fsS --max-time 8 -H "X-API-Key: $KEY" 'https://api.usemotion.com/v1/tasks' 2>/dev/null || true)"
  if [ -n "$JSON" ]; then
    printf "\n"; y; printf "📋  Motion — heute fällig / geplant"; z; printf "\n"
    OUT="$(echo "$JSON" | jq -r --arg d "$TODAY" '
      (.tasks // .) | map(select(
          ((.dueDate // "")        | startswith($d)) or
          ((.scheduledStart // "") | startswith($d))))
      | sort_by(.dueDate // "z")
      | .[]? | "  • \(.name)" + (if .dueDate then "  ⟶ " + (.dueDate[11:16]) else "" end)
    ' 2>/dev/null || true)"
    if [ -n "$OUT" ]; then printf "%s\n" "$OUT"
    else d; printf "  (heute nichts terminiert — oder API-Format abweichend)"; z; printf "\n"; fi
  fi
else
  printf "\n"; d; printf " Motion: kein API-Key -> pass insert motion/api-key"; z; printf "\n"
fi

# Newsboat ungelesen (nur Zahl, als Nudge)
if command -v newsboat >/dev/null 2>&1; then
  U="$(newsboat -x print-unread-count 2>/dev/null || true)"
  [ -n "$U" ] && { printf "\n"; cy; printf "📰  Newsboat: %s ungelesen   ->  newsboat" "$U"; z; printf "\n"; }
fi

# Fokus-Anker
rule
g; printf "🎯  Das EINE für heute:"; z; printf "  ________________________________\n"
d; printf "    2-Minuten-Regel: kleinste erste Handlung sofort tun.\n"; z; printf "\n"
